# Copy to .env and fill in. NEVER commit the real .env.
# --- database ---
DATABASE_URL=postgres://soulshard:soulshard@localhost:5432/soulshard
PG_POOL_MAX=10
# docker-compose 用:Postgres 密碼。本地 demo 可省略(預設 soulshard);
# 正式部署務必設定強密碼,docker-compose 的 db 與 DATABASE_URL 會一起套用。
# 產生:node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
POSTGRES_PASSWORD=

# --- auth ---
# MUST be >=32 random chars, or the server refuses to boot (forgeable-token guard).
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# (Local dev only, to run with a weak/empty secret: set ALLOW_INSECURE_JWT=1)
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=30d

# --- http ---
PORT=8787
HOST=0.0.0.0
# Comma-separated list of allowed browser origins (your game's URL).
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- admin ---
# Comma-separated account usernames allowed to open the 🛠 admin dashboard
# (server status / online players / kick / close room). Leave empty to disable.
ADMIN_USERS=

# --- telemetry (P1-3) ---
# Anonymous product-metrics retention in days. Rows in the `events` table older than this
# are purged at boot and every 24h. Default 90 if unset.
METRICS_RETENTION_DAYS=90
